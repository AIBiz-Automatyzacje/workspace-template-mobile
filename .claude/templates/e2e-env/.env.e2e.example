# Srodowisko E2E dev-autopilot — DEDYKOWANY projekt Supabase (NIGDY dev ani prod!)
# Setup: .claude/templates/e2e-env/README.md
# Skopiuj ten plik do korzenia repo jako `.env.e2e` i uzupelnij wartosci.
# `.env.e2e` MUSI byc w .gitignore — env-up odmowi startu, jesli nie jest.

# Projekt e2e (Supabase dashboard -> Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=https://<ref-projektu-e2e>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key-projektu-e2e>

# Polaczenie do bazy e2e (Settings -> Database -> Connection string).
# UWAGA: tryb "direct" (db.<ref>.supabase.co) jest IPv6-only — w sieciach bez trasy IPv6
# nie zadziala. Bezpieczniejszy default: SESSION POOLER (IPv4, port 5432, wspiera migracje):
SUPABASE_E2E_DB_URL=postgresql://postgres.<ref-projektu-e2e>:<haslo-db>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Service role (Settings -> API) — tylko do tworzenia konta testowego przez admin API
SUPABASE_E2E_SERVICE_ROLE_KEY=<service-role-key-projektu-e2e>

# Konto testowe do logowania w flow Maestro (email+haslo, NIE OAuth — Maestro nie przejdzie Google)
E2E_TEST_EMAIL=e2e@example.com
E2E_TEST_PASSWORD=<silne-haslo-testowe>
